PORT=3000

# SQL Server local
DB_SERVER=localhost
DB_INSTANCE=SQLEXPRESS
DB_NAME=mgevolution
DB_USER=sa
DB_PASS=
DB_ENCRYPT=false

# Azure SQL (descomente quando subir)
# DB_SERVER=seu-servidor.database.windows.net
# DB_INSTANCE=
# DB_ENCRYPT=true

JWT_SECRET=troque_por_string_longa_e_aleatoria
JWT_EXPIRES=8h

# CORS — domínio do frontend em produção (ex: https://meuapp.azurewebsites.net)
CORS_ORIGIN=

# WhatsApp App Secret — encontrado em Meta Developer > App > Configurações > App Secret
WHATSAPP_APP_SECRET=

# Mercado Pago
# Access Token em: mercadopago.com.br > Seu perfil > Credenciais > Credenciais de produção
MP_ACCESS_TOKEN=

# URL pública do backend (para o MP enviar webhooks)
BACKEND_URL=https://seu-backend.com

# URL do frontend (para redirecionamento após pagamento)
MP_BACK_URL=https://seu-site.com
