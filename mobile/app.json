{
  "expo": {
    "name": "MG Evolution",
    "slug": "mgevolution-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "mgevolution",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0EBE4"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mgevolution.mobile",
      "buildNumber": "7",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "pt-BR",
        "CFBundleLocalizations": [
          "pt-BR",
          "pt-BR"
        ],
        "NSFaceIDUsageDescription": "Use o Face ID para acessar o MG Evolution rapidamente.",
        "NSCameraUsageDescription": "O MG Evolution usa a câmera para adicionar fotos de evolução e perfil.",
        "NSPhotoLibraryUsageDescription": "O MG Evolution acessa a galeria para fotos de perfil e evolução.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#CC1A1A"
      },
      "package": "com.mgevolution.mobile",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "owner": "drauziojr",
    "extra": {
      "eas": {
        "projectId": "63c363ea-b5d7-4afa-8ed2-60a7c6e02168"
      },
      "devIp": "192.168.3.61",
      "router": {}
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use o Face ID para acessar o MG Evolution rapidamente."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#CC1A1A"
        }
      ],
      "expo-splash-screen",
      "expo-video",
      "expo-web-browser"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/63c363ea-b5d7-4afa-8ed2-60a7c6e02168"
    }
  }
}
